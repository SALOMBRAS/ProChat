# Para runtime Supabase + WhatsApp real, use supabase no .env.local ignorado.
DATABASE_PROVIDER=sqlite
CHATPRO_DATA_DIR=.chatpro-data
CHATPRO_DATABASE_PATH=.chatpro-data/backend.sqlite
WHATSAPP_CONNECTION_ENABLED=false
WHATSAPP_DEMO_MODE=false
WHATSAPP_PROVIDER=baileys
# Runtime real (npm run dev:whatsapp):
# DATABASE_PROVIDER=supabase
# WHATSAPP_DEMO_MODE=false
# WHATSAPP_CONNECTION_ENABLED=true
WHATSAPP_MAX_RECONNECT_ATTEMPTS=
WHATSAPP_RECONNECT_BASE_DELAY_MS=
WAHA_BASE_URL=http://127.0.0.1:3002
WAHA_API_KEY=
WAHA_TIMEOUT_MS=10000
# Required for private attachment storage when DATABASE_PROVIDER=supabase.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
